# pgflow — configuración de conexiones.
#
# Copia este archivo a ~/.pgflow.conf y rellena tus datos:
#     cp pgflow.conf.example ~/.pgflow.conf
#     chmod 600 ~/.pgflow.conf
#
# ~/.pgflow.conf NO se sube al repo (está en .gitignore).
# También puedes editarlo desde la app:  pgflow → Configurar conexiones.

# --- Local ---
PGFLOW_LOCAL_HOST="localhost"
PGFLOW_LOCAL_PORT="5432"
PGFLOW_LOCAL_USER="tu_usuario_local"
PGFLOW_LOCAL_PASS="tu_password_local"      # o déjalo vacío y usa ~/.pgpass

# --- Producción (a través de un túnel SSH) ---
# El alias debe existir en ~/.ssh/config con un LocalForward, p. ej.:
#   Host mi-servidor-db
#       HostName 1.2.3.4
#       User deploy
#       LocalForward 5433 localhost:5432
PGFLOW_PROD_SSH="mi-servidor-db"
PGFLOW_PROD_HOST="localhost"
PGFLOW_PROD_PORT="5433"                     # extremo local del túnel
PGFLOW_PROD_REMOTE_PORT="5432"             # puerto de postgres en el servidor
PGFLOW_PROD_USER="tu_usuario_prod"
PGFLOW_PROD_PASS=""                         # recomendado: vacío + ~/.pgpass

# --- Backups ---
PGFLOW_BACKUP_DIR="${HOME}/pgflow-backups"
